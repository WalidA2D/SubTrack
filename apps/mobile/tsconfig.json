{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@subly/shared": [
        "../../packages/shared/src"
      ],
      "@subly/shared/*": [
        "../../packages/shared/src/*"
      ]
    }
  },
  "include": [
    "App.tsx",
    "app.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
